# R2 credentials (required for upload + status.json handshake with gpu-service)
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=surveillance-data

# ===== Camera credentials (issue #21) =====
# Used by:
#   - ONVIF discovery (Stage 1) — passed to ONVIFCamera() so GetDeviceInformation
#     and GetStreamUri work on cameras that require auth (Hikvision-clones default)
#   - RTSP-scan fallback (Stage 2) — embedded as user:pass@ in the rtsp_url
#     so the operator can click → record without dropping into a terminal
#
# Default user/pass — applied to every camera that lacks a per-IP override.
# Most deployments need just these.
RTSP_DEFAULT_USER=
RTSP_DEFAULT_PASS=
#
# Per-IP override (uncomment + duplicate for each special-case camera).
# Convention: dots in the IP become underscores in the env var name.
# 192.168.50.2 → RTSP_CAM_192_168_50_2_USER / RTSP_CAM_192_168_50_2_PASS
#
# RTSP_CAM_192_168_50_2_USER=
# RTSP_CAM_192_168_50_2_PASS=

# Recorder / appliance behaviour
RTSP_DEFAULT_URL=
MAX_RECORDING_HOURS=8
