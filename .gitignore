models/*.pt
models/activity-mlp-*.json

# Test data
test-data/*.mp4
test-data/*.avi

# Issue #86 benchmark payloads are materialized from the immutable fixture
# release asset; Git tracks their manifest, hashes, and methodology only.
benchmarks/pose-resolution/bending-pilot-v1/frames/
benchmarks/pose-resolution/bending-pilot-v1/clips/
benchmarks/pose-resolution/films-v1/film-1/frames/
benchmarks/pose-resolution/films-v1/film-2/frames/

# Local test artifacts — commit notes/reports only, regenerate binaries from R2
jobs/*.mp4
jobs/*.html

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/
*.egg-info/
.pytest_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Environment
.env
.env.client
# The appliance's runtime env files live next to their .example templates —
# never commit the real ones; they carry R2 / camera creds.
client-appliance/*.env

# OS
.DS_Store
Thumbs.db

# Docker
.docker/

# IDE
.idea/
.vscode/
*.swp

