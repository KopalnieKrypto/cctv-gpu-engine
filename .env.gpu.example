# R2 credentials
R2_ENDPOINT=https://<account>.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=surveillance-data

# GPU service
SURVEILLANCE_GPU=0
MODELS_DIR=./models
POLL_INTERVAL_S=10

# Pipeline tuning
CONFIDENCE_THRESHOLD=0.25
SAMPLING_FPS=1
KEYFRAME_COUNT=5
KEYFRAME_MIN_SPACING_S=120
