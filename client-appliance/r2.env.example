# R2 (Cloudflare S3-compatible) credentials for the gpu-service to pick up
# recordings uploaded by this appliance. Copy to /etc/cctv-client/r2.env, fill
# in the four values below, then `chmod 600 /etc/cctv-client/r2.env`.
#
# Format: KEY=VALUE per line, no quotes, no spaces around =. Loaded by systemd
# via EnvironmentFile= and by the appliance's --env-dir loader.

# Account-scoped S3 endpoint, e.g. https://<accountid>.r2.cloudflarestorage.com
R2_ENDPOINT=

# Access key pair from a Cloudflare R2 API token with "Object Read & Write"
# scoped to the surveillance-data bucket.
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=

# Bucket name. Defaults to surveillance-data if unset; override only if your
# tenant uses a different bucket.
R2_BUCKET=surveillance-data
