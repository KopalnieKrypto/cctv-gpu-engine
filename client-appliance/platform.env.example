# GPU Exchange platform integration (issue #26). Optional — leave unset to
# run the appliance in legacy standalone mode (auto-fallback). Copy to
# /etc/cctv-client/platform.env, fill in the two values below, then
# `chmod 600 /etc/cctv-client/platform.env`.
#
# Format: KEY=VALUE per line, no quotes, no spaces around =. Loaded by
# systemd via EnvironmentFile= and by the appliance's --env-dir loader.
#
# When both keys are set, the appliance boots in platform mode:
#   register → discover → push_cameras → heartbeat → recorder spawn.
# When either is missing, the appliance falls back to standalone Phase 1-3
# behaviour (Flask UI :8080, manual recordings, no platform callbacks).

# Base URL of the GPU Exchange platform (no trailing slash).
PLATFORM_URL=

# Bearer token issued by the platform admin UI. Plain text is shown to the
# operator exactly once at generation time; the platform stores a bcrypt
# hash. Token rotation is a manual operator action — restart the unit
# (`systemctl restart cctv-client`) after editing this file.
APPLIANCE_TOKEN=

# Rolling-buffer retention window in hours (issue #30). 1h is the
# dev/MVP default that ships out of the box. Production appliances
# should set this to 8 hours or more so historical task requests have
# enough buffered footage to satisfy a wider window. A value below 1
# or a non-numeric typo fails the appliance at boot — there is no
# silent fallback.
#
#   # Production: keep 8h of footage per camera
#   # BUFFER_HOURS=8
BUFFER_HOURS=1
