# RTSP credentials for cameras discovered via ONVIF (issue #21) and recorded
# by the appliance. Copy to /etc/cctv-client/cameras.env, fill in real
# user/password values, then `chmod 600 /etc/cctv-client/cameras.env`.
#
# Resolution order (per client_agent.discovery._credentials_for):
#   1) RTSP_CAM_<sanitized_ip>_USER + RTSP_CAM_<sanitized_ip>_PASS  (per-IP)
#   2) RTSP_DEFAULT_USER          + RTSP_DEFAULT_PASS               (fallback)
#   3) error 400 if neither set
#
# Sanitization: dots in the IP become underscores. So 192.168.50.2 maps to
# RTSP_CAM_192_168_50_2_USER (and ..._PASS).

# Default user/pass — applied to every camera unless an override below wins.
# Most operators only need these two lines.
RTSP_DEFAULT_USER=admin
RTSP_DEFAULT_PASS=changeme

# Per-IP overrides — only set if a specific camera uses different creds.
# Example below is for camera at 192.168.50.2; replicate the pattern for
# additional IPs.
#RTSP_CAM_192_168_50_2_USER=admin
#RTSP_CAM_192_168_50_2_PASS=other-password

# --- RTSP path probing (issue #74) ---------------------------------------
# White-label / no-brand IP cameras often expose :554 but advertise no vendor
# fingerprint (no RTSP "Server:" header, no proprietary port), so discovery
# can't guess their stream path and used to strand them as "needs manual URL".
# Stage 2.5 now *probes* a candidate path list with a real ffmpeg open and
# keeps the first path that actually streams.
#
# RTSP_KNOWN_URLS — comma/space-separated list of FULL working RTSP URLs for
#   any camera you've already confirmed. Discovery lifts each URL's path and
#   tries it FIRST against look-alike siblings (same batch/model on the LAN),
#   so one confirmed camera teaches the rest. Recommended when you have a
#   mixed or unusual fleet.
#RTSP_KNOWN_URLS=rtsp://192.168.50.9:554/unicast/c1/s0/live
#
# RTSP_PROBE_PATHS — comma/space-separated extra candidate paths (leading "/"
#   optional) appended after RTSP_KNOWN_URLS and before the built-in defaults.
#RTSP_PROBE_PATHS=/live/ch00_0,/onvif1
